{
  "name": "effectclanker",
  "version": "0.0.1",
  "private": true,
  "description": "A learning-grade coding harness built on Effect-TS. Tools, registry, and dispatch modeled after Codex.",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint packages",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run test"
  },
  "devDependencies": {
    "@effect/ai": "^0.35.0",
    "@effect/ai-anthropic": "^0.25.0",
    "@effect/cli": "^0.75.0",
    "@effect/platform": "^0.96.0",
    "@effect/platform-node": "^0.106.0",
    "@effect/vitest": "^0.29.0",
    "@effectclanker/cli": "workspace:*",
    "@effectclanker/harness": "workspace:*",
    "@effectclanker/tools": "workspace:*",
    "@effectclanker/tui": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "effect": "^3.21.0",
    "ink": "^7.0.3",
    "ink-text-input": "^6.0.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "react": "^19.2.6",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
